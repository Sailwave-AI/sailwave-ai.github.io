---
import { url } from '../utils';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'IA para asesorías y gestorías';
const description =
  'Automatización con IA para asesorías y gestorías: picado de facturas y nóminas, recordatorios de plazos, respuestas a consultas y onboarding. Menos horas administrativas y más capacidad para crecer. Proyectos con precio cerrado, sin humo.';

const updated = '2026-06-14';

// Automatizaciones que más liberan
const automations = [
  {
    title: 'Procesado de facturas y nóminas',
    desc: 'La IA extrae los datos de facturas, albaranes y documentos en PDF o foto, los deja listos para tu programa de contabilidad y te marca lo que no cuadra. Se acaba el picado a mano.',
  },
  {
    title: 'Recordatorios de plazos a clientes',
    desc: 'Avisos automáticos de impuestos, vencimientos y documentación pendiente, con el tono de tu despacho. Menos clientes despistados, menos correos tuyos persiguiéndoles.',
  },
  {
    title: 'Respuestas a consultas repetitivas',
    desc: 'Un asistente que contesta por correo o WhatsApp las preguntas de siempre ("¿qué necesito para la renta?", "¿cuándo sale la nómina?") y solo te pasa lo que requiere a un profesional.',
  },
  {
    title: 'Onboarding de cliente nuevo',
    desc: 'Recogida de documentación, altas y carpetas montadas sin que nadie del equipo tenga que ir paso a paso. Cada alta nueva deja de ser un pequeño caos.',
  },
];

// Ángulo de crecimiento
const growth = [
  {
    title: 'Más capacidad sin contratar',
    desc: 'Absorbe los picos —campaña de renta, cierres trimestrales, vencimientos— con el mismo equipo. Atiende a más clientes sin sumar nóminas ni quemar a la plantilla.',
  },
  {
    title: 'Clientes que se quedan',
    desc: 'Respuestas rápidas, plazos cumplidos y avisos proactivos. El cliente nota el servicio, y un cliente bien atendido renueva y te trae referidos.',
  },
  {
    title: 'Tiempo para el asesoramiento',
    desc: 'Menos horas en tareas que no se facturan, más horas para el asesoramiento de valor y para captar la cartera que de verdad hace crecer el despacho.',
  },
];

const faqs = [
  {
    q: '¿Tengo que cambiar de programa de gestión?',
    a: 'No. Las automatizaciones se conectan a lo que ya usas (tu software de contabilidad o nóminas, el correo, Excel) sin obligarte a migrar. El objetivo es quitar trabajo manual, no montarte una reforma.',
  },
  {
    q: '¿Es seguro con datos fiscales y de clientes?',
    a: 'Sí. Se trabaja con herramientas que cumplen RGPD, las credenciales se contratan a tu nombre y los datos sensibles solo se mueven entre tus sistemas. Tú eres el dueño de todo lo que se monta.',
  },
  {
    q: '¿Cuánto se tarda y cuánto cuesta?',
    a: 'Un diagnóstico te dice en dos semanas qué procesos compensa automatizar, cuánto ahorras y cuánto costaría implantarlo, con un presupuesto cerrado por escrito. La implantación se hace en 2-4 semanas, siempre con el precio acordado antes de empezar.',
  },
  {
    q: '¿Sirve para una asesoría pequeña?',
    a: 'Especialmente. Cuanto más pesa el trabajo repetitivo sobre pocas personas, más se nota recuperar horas en cada cierre. No hace falta tener un gran departamento de sistemas.',
  },
  {
    q: '¿Puedo ofrecer estas automatizaciones a mis propios clientes?',
    a: 'Lo que montamos para tu despacho te sirve también para abrir esa conversación con tu cartera. Empezamos por tu casa: cuando lo ves funcionar, decides si quieres llevarlo a tus clientes.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Automatización con IA para asesorías y gestorías',
  serviceType: 'Automatización de procesos con IA',
  description,
  areaServed: { '@type': 'Country', name: 'España' },
  provider: { '@type': 'ProfessionalService', name: 'Eraldia', url: new URL(url('/'), Astro.url).href },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} ogType="article" publishedTime={updated}>

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<!-- Cabecera -->
<section class="pb-hero">
  <div class="pb-hero__inner">
    <span class="hero__badge">IA para asesorías y gestorías</span>
    <h1 class="pb-hero__title">Pon tu asesoría al día con la IA</h1>
    <p class="pb-hero__subtitle">
      Donde más papel y más plazos hay, más se nota la automatización. Menos picado, menos consultas
      repetidas y cierres sin agobios —y la capacidad para atender a más clientes sin contratar.
    </p>
    <div class="hero__actions">
      <a href={url('/#contacto')} class="btn btn--primary btn--lg">Pide tu diagnóstico gratuito</a>
      <a href={url('/diagnostico-express/')} class="btn btn--outline-white btn--lg">Diagnóstico exprés (1 min)</a>
    </div>
    <p class="pb-hero__meta">
      <span>Precio cerrado</span><span>·</span><span>2–4 semanas</span><span>·</span><span>herramientas a tu nombre</span>
    </p>
  </div>
</section>

<!-- Respuesta directa (GEO) -->
<section class="section">
  <div class="container container--narrow">
    <div class="pb-answer reveal">
      <span class="pb-answer__label">En una frase</span>
      <p>
        <strong>Una asesoría vive de plazos y de papel</strong>: facturas que picar, nóminas que cuadrar,
        modelos que presentar antes de una fecha y las mismas consultas una y otra vez. Es justo el tipo de
        trabajo —repetitivo, con reglas claras y mucho volumen— donde la automatización con IA da el
        retorno más rápido y más medible de cualquier sector. No se trata de cambiar tu forma de trabajar,
        sino de quitar de en medio las horas que no necesitan tu criterio profesional.
      </p>
    </div>
  </div>
</section>

<!-- Automatizaciones -->
<section class="section section--alt">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Las automatizaciones que más liberan en una asesoría</h2>
      <p class="section__subtitle">
        Cuatro procesos que se repiten cada mes y cada trimestre. En cuanto funcionan para un cierre,
        funcionan para todos los siguientes.
      </p>
    </div>
    <div class="grid grid--2 reveal-stagger">
      {automations.map((a) => (
        <div class="card reveal">
          <h3 class="card__title">{a.title}</h3>
          <p class="card__desc">{a.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Crecimiento -->
<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">No es solo ahorrar horas: es crecer</h2>
      <p class="section__subtitle">
        Las horas que recuperas se convierten en capacidad. Eso es lo que impulsa el negocio, no solo recortar costes.
      </p>
    </div>
    <div class="grid grid--3 reveal-stagger">
      {growth.map((g) => (
        <div class="card reveal">
          <h3 class="card__title">{g.title}</h3>
          <p class="card__desc">{g.desc}</p>
        </div>
      ))}
    </div>
    <div class="pb-pullquote" style="margin-top: 3rem; text-align: center;">
      Una asesoría al día con la IA no trabaja más horas: atiende a más clientes con las mismas.
    </div>
  </div>
</section>

<!-- Cómo lo hacemos + precios -->
<section class="section section--alt">
  <div class="container container--narrow">
    <div class="section__header">
      <h2 class="section__title">Cómo lo hacemos</h2>
      <p class="section__subtitle">Una escalera de tres pasos, con precio cerrado por escrito en cada uno. Empiezas por el primero y decides después.</p>
    </div>
    <div class="pb-table-wrap">
      <table class="pb-table">
        <thead>
          <tr><th>Paso</th><th>Qué recibes</th></tr>
        </thead>
        <tbody>
          <tr><td><a href={url('/servicios/diagnostico-ia/')}>Diagnóstico de IA</a></td><td>En 2 semanas: el mapa de tus procesos, las 2-3 automatizaciones con más ahorro y su coste cerrado.</td></tr>
          <tr><td><a href={url('/servicios/automatizacion/')}>Automatización a medida</a></td><td>Implantación en 2-4 semanas, equipo formado y herramientas a tu nombre.</td></tr>
          <tr><td><a href={url('/servicios/acompanamiento/')}>Acompañamiento</a></td><td>Mantenimiento, mejoras y formación continua, sin permanencia.</td></tr>
        </tbody>
      </table>
    </div>
    <p style="text-align:center; margin-top:1.5rem;">
      ¿Quieres el método completo, gratis? Lee el <a href={url('/playbook/')}>playbook de IA agéntica para pymes</a>.
    </p>
  </div>
</section>

<!-- FAQ -->
<section class="section">
  <div class="container container--narrow">
    <div class="section__header">
      <h2 class="section__title">Preguntas frecuentes</h2>
    </div>
    <div class="faq__list">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__question">{f.q}</summary>
          <p class="faq__answer">{f.a}</p>
        </details>
      ))}
    </div>

    <nav class="related-sectores" aria-label="Más">
      <h2 class="related-sectores__title">Seguir leyendo</h2>
      <ul class="related-sectores__list">
        <li><a href={url('/ia-para-abogados/')} class="related-sectores__link">IA para despachos de abogados</a></li>
        <li><a href={url('/blog/cuanto-cuesta-automatizacion-ia-pyme/')} class="related-sectores__link">Cuánto cuesta automatizar con IA</a></li>
        <li><a href={url('/playbook/')} class="related-sectores__link">Playbook de IA</a></li>
        <li><a href={url('/casos/')} class="related-sectores__link">Otros sectores</a></li>
      </ul>
    </nav>
  </div>
</section>

<!-- CTA final -->
<section class="section">
  <div class="container">
    <div class="cta cta--inline cta--dark reveal" aria-label="Contacto">
      <div class="cta__inner">
        <h2 class="cta__title">¿Lo vemos en tu asesoría?</h2>
        <p class="cta__desc">
          Cuéntame en dos líneas qué proceso te quita más tiempo y te digo, sin humo, si la IA puede ayudarte y cuánto costaría.
        </p>
        <a href={url('/#contacto')} class="btn btn--primary btn--lg">Hablamos 30 minutos, gratis</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
