---
import { url } from '../utils';
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'IA para despachos de abogados';
const description =
  'Automatización con IA para despachos de abogados: resumen y búsqueda en expedientes, control de plazos procesales, intake de clientes y consultas repetitivas. Menos horas administrativas, más horas facturables. Proyectos con precio cerrado, sin humo.';

const updated = '2026-06-14';

const automations = [
  {
    title: 'Resumen y búsqueda en documentos',
    desc: 'Resúmenes de expedientes y contratos largos, localización de cláusulas y datos concretos, comparación de versiones. Lo que era una tarde de lectura, en minutos —para revisar, no para confiar a ciegas.',
  },
  {
    title: 'Control de plazos procesales',
    desc: 'Avisos automáticos de vencimientos y señalamientos para que ningún plazo dependa de que alguien se acuerde. La tranquilidad de no jugártela a la memoria.',
  },
  {
    title: 'Intake y consultas repetitivas',
    desc: 'Un asistente que recoge los datos del cliente nuevo y responde las preguntas iniciales de siempre, y deriva al abogado lo que requiere criterio jurídico.',
  },
  {
    title: 'Borradores y documentación rutinaria',
    desc: 'Primeros borradores de escritos repetitivos y ordenación de la documentación de cada caso, listos para que el abogado revise y dé el visto bueno.',
  },
];

const growth = [
  {
    title: 'Más casos sin más horas',
    desc: 'Llevar más asuntos con el mismo equipo, porque lo administrativo deja de comerse el día. La capacidad del despacho crece sin contratar.',
  },
  {
    title: 'Clientes mejor atendidos',
    desc: 'Respuestas rápidas en el intake, plazos controlados y comunicación proactiva. El cliente percibe un despacho que va por delante, y eso retiene y trae recomendaciones.',
  },
  {
    title: 'Más horas facturables',
    desc: 'Cada hora administrativa que se recupera es tiempo que vuelve a lo jurídico: lo que de verdad aporta valor y se factura.',
  },
];

const faqs = [
  {
    q: '¿La IA da asesoramiento jurídico?',
    a: 'No. Asiste en lo repetitivo —resumir un expediente, localizar una cláusula, preparar un borrador inicial, ordenar documentación— para ahorrar horas administrativas. El criterio jurídico y la responsabilidad son siempre del abogado.',
  },
  {
    q: '¿Qué pasa con la confidencialidad y el secreto profesional?',
    a: 'Es el punto crítico y se trata como tal: herramientas que cumplen RGPD, datos que solo se mueven entre tus sistemas, planes de empresa que no entrenan con tu información y credenciales a tu nombre. En el diagnóstico se define qué información puede tratarse y cómo, antes de montar nada.',
  },
  {
    q: '¿Cuánto cuesta y cuánto tarda?',
    a: 'El diagnóstico prioriza en dos semanas las automatizaciones con más retorno y cierra el presupuesto de cada una. La implantación se hace en 2-4 semanas, siempre con el precio acordado por escrito antes de empezar.',
  },
  {
    q: '¿Sirve para un despacho pequeño o un abogado individual?',
    a: 'Sí. Cuanto más recae el trabajo administrativo sobre pocas personas, más vale recuperar esas horas. No hace falta una gran infraestructura: se empieza por un proceso concreto.',
  },
  {
    q: '¿Tengo que cambiar mi software de gestión de expedientes?',
    a: 'No. Las automatizaciones se conectan a lo que ya usas. El objetivo es quitar trabajo manual sobre tus sistemas actuales, no obligarte a migrar.',
  },
];

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: 'Automatización con IA para despachos de abogados',
  serviceType: 'Automatización de procesos con IA',
  description,
  areaServed: { '@type': 'Country', name: 'España' },
  provider: { '@type': 'ProfessionalService', name: 'Eraldia', url: new URL(url('/'), Astro.url).href },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<BaseLayout title={title} description={description} ogType="article" publishedTime={updated}>

<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

<!-- Cabecera -->
<section class="pb-hero">
  <div class="pb-hero__inner">
    <span class="hero__badge">IA para despachos de abogados</span>
    <h1 class="pb-hero__title">Pon tu despacho al día con la IA</h1>
    <p class="pb-hero__subtitle">
      Mucho documento, muchos plazos y horas que se van en tareas administrativas. La IA se ocupa de
      lo repetitivo —siempre bajo tu supervisión— para que el despacho dedique el tiempo a lo jurídico.
    </p>
    <div class="hero__actions">
      <a href={url('/#contacto')} class="btn btn--primary btn--lg">Pide tu diagnóstico gratuito</a>
      <a href={url('/diagnostico-express/')} class="btn btn--outline-white btn--lg">Diagnóstico exprés (1 min)</a>
    </div>
    <p class="pb-hero__meta">
      <span>Precio cerrado</span><span>·</span><span>2–4 semanas</span><span>·</span><span>secreto profesional por delante</span>
    </p>
  </div>
</section>

<!-- Respuesta directa (GEO) -->
<section class="section">
  <div class="container container--narrow">
    <div class="pb-answer reveal">
      <span class="pb-answer__label">En una frase</span>
      <p>
        <strong>En un despacho, buena parte del día se va en tareas que no son ejercer la abogacía</strong>:
        leer y resumir documentación, buscar una cláusula entre cientos de páginas, controlar plazos,
        preparar borradores rutinarios y atender las mismas consultas iniciales una y otra vez. Son horas
        que no se facturan y que queman. La automatización con IA se ocupa de ese trabajo repetitivo,
        siempre bajo tu supervisión, para devolver esas horas a lo jurídico.
      </p>
    </div>
  </div>
</section>

<!-- Automatizaciones -->
<section class="section section--alt">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Las automatizaciones que más horas devuelven</h2>
      <p class="section__subtitle">
        El trabajo legal es intensivo en documento y en plazo, y se repite entre casos: una automatización
        bien acotada rinde en todos los expedientes siguientes.
      </p>
    </div>
    <div class="grid grid--2 reveal-stagger">
      {automations.map((a) => (
        <div class="card reveal">
          <h3 class="card__title">{a.title}</h3>
          <p class="card__desc">{a.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Crecimiento -->
<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">No es solo ahorrar horas: es crecer</h2>
      <p class="section__subtitle">
        Las tarifas por hora son altas: cada hora administrativa que se recupera vale mucho —y se puede
        dedicar a llevar más casos o a captar.
      </p>
    </div>
    <div class="grid grid--3 reveal-stagger">
      {growth.map((g) => (
        <div class="card reveal">
          <h3 class="card__title">{g.title}</h3>
          <p class="card__desc">{g.desc}</p>
        </div>
      ))}
    </div>
    <div class="pb-pullquote" style="margin-top: 3rem; text-align: center;">
      Cada hora administrativa que recupera un despacho es una hora que vuelve a lo jurídico.
    </div>
  </div>
</section>

<!-- Confidencialidad -->
<section class="section section--alt">
  <div class="container container--narrow">
    <div class="pb-answer reveal" style="border-left-color: var(--sage, #8FA277);">
      <span class="pb-answer__label">Lo primero: la confidencialidad</span>
      <p>
        El secreto profesional no es un añadido, es el punto de partida. Se trabaja con herramientas que
        cumplen RGPD y con planes de empresa que <strong>no entrenan con tu información</strong>; los datos
        solo se mueven entre tus sistemas; el agente accede a lo mínimo imprescindible; y las credenciales
        se contratan a tu nombre. En el diagnóstico se define qué información puede tratarse y cómo,
        <strong>antes de montar nada</strong>.
      </p>
    </div>
  </div>
</section>

<!-- Cómo lo hacemos + precios -->
<section class="section">
  <div class="container container--narrow">
    <div class="section__header">
      <h2 class="section__title">Cómo lo hacemos</h2>
      <p class="section__subtitle">Una escalera de tres pasos, con precio cerrado por escrito en cada uno. Empiezas por el primero y decides después.</p>
    </div>
    <div class="pb-table-wrap">
      <table class="pb-table">
        <thead>
          <tr><th>Paso</th><th>Qué recibes</th></tr>
        </thead>
        <tbody>
          <tr><td><a href={url('/servicios/diagnostico-ia/')}>Diagnóstico de IA</a></td><td>En 2 semanas: el mapa de tus procesos, las automatizaciones con más retorno y qué información puede tratarse.</td></tr>
          <tr><td><a href={url('/servicios/automatizacion/')}>Automatización a medida</a></td><td>Implantación en 2-4 semanas, equipo formado y herramientas a tu nombre.</td></tr>
          <tr><td><a href={url('/servicios/acompanamiento/')}>Acompañamiento</a></td><td>Mantenimiento, mejoras y formación continua, sin permanencia.</td></tr>
        </tbody>
      </table>
    </div>
    <p style="text-align:center; margin-top:1.5rem;">
      ¿Quieres el método completo, gratis? Lee el <a href={url('/playbook/')}>playbook de IA agéntica para pymes</a>.
    </p>
  </div>
</section>

<!-- FAQ -->
<section class="section section--alt">
  <div class="container container--narrow">
    <div class="section__header">
      <h2 class="section__title">Preguntas frecuentes</h2>
    </div>
    <div class="faq__list">
      {faqs.map((f) => (
        <details class="faq__item">
          <summary class="faq__question">{f.q}</summary>
          <p class="faq__answer">{f.a}</p>
        </details>
      ))}
    </div>

    <nav class="related-sectores" aria-label="Más">
      <h2 class="related-sectores__title">Seguir leyendo</h2>
      <ul class="related-sectores__list">
        <li><a href={url('/ia-para-asesorias/')} class="related-sectores__link">IA para asesorías y gestorías</a></li>
        <li><a href={url('/blog/cuanto-cuesta-automatizacion-ia-pyme/')} class="related-sectores__link">Cuánto cuesta automatizar con IA</a></li>
        <li><a href={url('/playbook/')} class="related-sectores__link">Playbook de IA</a></li>
        <li><a href={url('/casos/')} class="related-sectores__link">Otros sectores</a></li>
      </ul>
    </nav>
  </div>
</section>

<!-- CTA final -->
<section class="section">
  <div class="container">
    <div class="cta cta--inline cta--dark reveal" aria-label="Contacto">
      <div class="cta__inner">
        <h2 class="cta__title">¿Lo vemos en tu despacho?</h2>
        <p class="cta__desc">
          Cuéntame en dos líneas qué tarea os come más tiempo y te digo, sin humo, si la IA puede ayudaros y cuánto costaría —con la confidencialidad por delante.
        </p>
        <a href={url('/#contacto')} class="btn btn--primary btn--lg">Hablamos 30 minutos, gratis</a>
      </div>
    </div>
  </div>
</section>

</BaseLayout>
