---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog');

// Collect all unique tags
const tagMap = new Map<string, number>();
for (const post of posts) {
  for (const tag of (post.data.tags ?? [])) {
    tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
  }
}
const tags = [...tagMap.entries()].sort((a, b) => a[0].localeCompare(b[0], 'es'));
---

<BaseLayout title="Etiquetas" description="Todos los artículos del blog organizados por etiqueta.">

<div class="page-header">
  <div class="container">
    <h1 class="page-header__title">Etiquetas</h1>
  </div>
</div>

<section class="section">
  <div class="container container--narrow">
    {tags.length > 0 ? (
      <div class="tags" style="gap: 0.75rem; flex-wrap: wrap; display: flex;">
        {tags.map(([tag, count]) => (
          <a href={`/tags/${tag}/`} class="tag" style="font-size: 1rem; padding: 0.5rem 1rem;">
            {tag} <small style="opacity: 0.65;">({count})</small>
          </a>
        ))}
      </div>
    ) : (
      <div class="empty-state">
        <p class="empty-state__text">No hay etiquetas todavía.</p>
      </div>
    )}
  </div>
</section>

</BaseLayout>
