---
import { url } from '../utils';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, TAGLINE, CONTACT_EMAIL } from '../consts';
---

<BaseLayout
  title={undefined}
  description={SITE_DESCRIPTION}
  isHome={true}
>

<!-- ================================================================ -->
<!-- Hero Section                                                       -->
<!-- ================================================================ -->
<section class="hero" style={`background-image: url('${url('/images/hero/hero-background.jpg')}')`}>
  <div class="hero__fx" aria-hidden="true">
    <span class="hero__orb hero__orb--one"></span>
    <span class="hero__orb hero__orb--two"></span>
    <span class="hero__orb hero__orb--three"></span>
    <span class="hero__grid"></span>
  </div>
  <div class="container hero__inner">
    <span class="hero__badge">IA para asesorías y despachos</span>
    <h1 class="hero__title">
      Pon tu asesoría o despacho al día con la IA
    </h1>
    <p class="hero__subtitle">
      Te quito el trabajo repetitivo —facturas, plazos, consultas y expedientes— y te doy capacidad para atender a más clientes sin contratar. Precio cerrado, resultados medibles y cero humo.
    </p>
    <div class="hero__actions">
      <a href="#contacto" class="btn btn--primary btn--lg">Pide tu diagnóstico gratuito</a>
      <a href={url('/diagnostico-express/')} class="btn btn--outline btn--lg">Diagnóstico exprés (1 min)</a>
    </div>
    <p class="hero__actions-note">
      Mira cómo trabajo con <a href={url('/ia-para-asesorias/')}>asesorías y gestorías</a> o con <a href={url('/ia-para-abogados/')}>despachos de abogados</a>. ¿Otro tipo de pyme? También — <a href={url('/casos/')}>cuéntame tu caso</a>. O lee gratis el <a href={url('/playbook/')}>playbook de IA</a>.
    </p>
    <div class="hero__stats">
      <div class="hero__stat">
        <span class="hero__stat-number">30</span>
        <span class="hero__stat-unit">min</span>
        <span class="hero__stat-label">de llamada inicial, gratis y sin compromiso</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-number">2&ndash;4</span>
        <span class="hero__stat-unit">semanas</span>
        <span class="hero__stat-label">por proyecto, de la idea a funcionando</span>
      </div>
      <div class="hero__stat">
        <span class="hero__stat-number">100%</span>
        <span class="hero__stat-unit"></span>
        <span class="hero__stat-label">precio cerrado antes de empezar</span>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Problem Statement                                                  -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="section__header reveal">
      <h2 class="section__title">La IA no es el problema. El humo, sí.</h2>
      <p class="section__subtitle">
        Cada semana te ofrecen una herramienta que "lo cambia todo" y, mientras tanto, en tu despacho se siguen picando facturas a mano, persiguiendo documentación a los clientes, vigilando plazos y respondiendo las mismas consultas una y otra vez. No necesitas otra suscripción: necesitas saber qué automatizar, cuánto cuesta y cuántas horas te devuelve. Eso es lo que hago.
      </p>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Vertical focus — asesorías y despachos                             -->
<!-- ================================================================ -->
<section class="section section--alt">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Pensado para asesorías y despachos</h2>
      <p class="section__subtitle">
        Dos focos, el mismo método. Elige el tuyo y mira las automatizaciones concretas y lo que cuestan.
      </p>
    </div>

    <div class="grid grid--2 reveal-stagger">
      <a href={url('/ia-para-asesorias/')} class="service-card reveal">
        <div class="service-card__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="8" y1="13" x2="16" y2="13"/><line x1="8" y1="17" x2="13" y2="17"/>
          </svg>
        </div>
        <h3 class="service-card__title">IA para asesorías y gestorías</h3>
        <p class="service-card__desc">
          Picado de facturas y nóminas, recordatorios de plazos a clientes, respuestas a las consultas de siempre y onboarding sin caos. Llega a la campaña de renta y a cada cierre con margen.
        </p>
        <span class="service-card__action">Ver automatizaciones y precios</span>
      </a>

      <a href={url('/ia-para-abogados/')} class="service-card reveal">
        <div class="service-card__icon">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/>
          </svg>
        </div>
        <h3 class="service-card__title">IA para despachos de abogados</h3>
        <p class="service-card__desc">
          Resumen y búsqueda en expedientes, control de plazos procesales, intake de clientes y respuestas iniciales —siempre bajo tu supervisión y con el secreto profesional por delante.
        </p>
        <span class="service-card__action">Ver automatizaciones y precios</span>
      </a>
    </div>

    <div class="section__header" style="margin-top: 4rem; margin-bottom: 2rem;">
      <h2 class="section__title">No es solo ahorrar horas: es crecer</h2>
      <p class="section__subtitle">
        Las horas que recuperas no se evaporan: se convierten en capacidad para atender mejor y a más clientes.
      </p>
    </div>

    <div class="grid grid--3 reveal-stagger">
      <div class="card reveal">
        <h3 class="card__title">Más capacidad sin contratar</h3>
        <p class="card__desc">Atiende más clientes y expedientes con el mismo equipo. La automatización absorbe los picos —renta, cierres, vencimientos— sin sumar nóminas.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">Clientes que se quedan</h3>
        <p class="card__desc">Respuestas rápidas, plazos cumplidos y avisos proactivos. El cliente nota el servicio, y eso es lo que retiene y trae referidos.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">Tiempo para lo que de verdad vale</h3>
        <p class="card__desc">Menos horas administrativas que no se facturan, más horas para el asesoramiento y la captación que mueven el negocio.</p>
      </div>
    </div>

    <div class="pb-pullquote" style="margin-top: 3rem; text-align: center;">
      Una asesoría al día con la IA no trabaja más horas: atiende a más clientes con las mismas.
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Service Pillars                                                    -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Tres servicios, una escalera</h2>
      <p class="section__subtitle">
        Empieza por el primer escalón y decide después. Cada servicio tiene valor por sí mismo: sin permanencias y sin letra pequeña.
      </p>
    </div>

    <div class="grid grid--3 reveal-stagger">
      <!-- Pilar 1: Diagnóstico -->
      <a href={url('/servicios/diagnostico-ia/')} class="card card--link reveal">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
          </svg>
        </div>
        <h3 class="card__title">1. Diagnóstico de IA</h3>
        <p class="card__desc">
          En dos semanas sabes qué procesos merece la pena automatizar, cuánto cuesta y qué ahorro esperar. Desde 490&nbsp;&euro;, descontable del proyecto.
        </p>
        <span class="card__link">Saber más</span>
      </a>

      <!-- Pilar 2: Automatización -->
      <a href={url('/servicios/automatizacion/')} class="card card--link reveal">
        <div class="card__icon card__icon--accent">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
          </svg>
        </div>
        <h3 class="card__title">2. Automatización a medida</h3>
        <p class="card__desc">
          Implanto la automatización en tu negocio en 2-4 semanas: atención al cliente, presupuestos, facturas, informes. Proyecto cerrado desde 1.900&nbsp;&euro;.
        </p>
        <span class="card__link">Saber más</span>
      </a>

      <!-- Pilar 3: Acompañamiento -->
      <a href={url('/servicios/acompanamiento/')} class="card card--link reveal">
        <div class="card__icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
          </svg>
        </div>
        <h3 class="card__title">3. Acompañamiento mensual</h3>
        <p class="card__desc">
          Mantenimiento, mejoras y formación continua para tu equipo. Tu socio tecnológico desde 390&nbsp;&euro;/mes, sin permanencia.
        </p>
        <span class="card__link">Saber más</span>
      </a>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- How I Work                                                         -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="section__header">
      <h2 class="section__title">Cómo trabajo</h2>
      <p class="section__subtitle">
        Un proceso simple, pensado para que en cada paso sepas qué recibes y cuánto cuesta.
      </p>
    </div>

    <div class="grid grid--4 reveal-stagger">
      <div class="card reveal">
        <h3 class="card__title">1. Hablamos</h3>
        <p class="card__desc">Llamada de 30 minutos, gratis. Me cuentas tu negocio y te digo con honestidad si la IA puede ayudarte o no.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">2. Diagnóstico</h3>
        <p class="card__desc">Analizo tus procesos y te entrego un plan con las automatizaciones priorizadas, su coste y su ahorro estimado.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">3. Implantación</h3>
        <p class="card__desc">Construyo la automatización con alcance, plazo y precio cerrados por escrito. Ves avances cada semana.</p>
      </div>
      <div class="card reveal">
        <h3 class="card__title">4. Acompañamiento</h3>
        <p class="card__desc">Formación para tu equipo y, si quieres, mantenimiento y mejora continua mes a mes. Sin permanencia.</p>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Mid CTA — Diagnóstico gratuito                                     -->
<!-- ================================================================ -->
<section class="section">
  <div class="container">
    <div class="cta cta--inline reveal" aria-label="Pide tu diagnóstico gratuito">
      <div class="cta__inner">
        <h2 class="cta__title">Empieza con 30 minutos, gratis</h2>
        <p class="cta__desc">
          Una llamada sin compromiso en la que repasamos tu negocio y te llevas valor desde el primer día, contrates o no.
        </p>
        <ul class="cta__benefits">
          <li>Una foto rápida de tus procesos y dónde pierdes horas</li>
          <li>Las 2-3 automatizaciones con más potencial en tu caso</li>
          <li>Una opinión honesta: si la IA no te va a ayudar, te lo digo</li>
        </ul>
        <a href="#contacto" class="btn btn--outline-white btn--lg">Reservar mi llamada</a>
        <a href={url('/diagnostico-express/')} class="btn btn--outline-white btn--lg">Haz el diagnóstico exprés (1 min)</a>
      </div>
    </div>
  </div>
</section>

<!-- ================================================================ -->
<!-- Contact form — lead capture                                        -->
<!-- ================================================================ -->
<section class="section section--alt" id="contacto">
  <div class="container container--narrow">
    <div class="section__header">
      <h2 class="section__title">Cuéntame qué te quita tiempo</h2>
      <p class="section__subtitle">
        Escríbeme dos líneas sobre tu negocio y te respondo en menos de 24 horas laborables con los siguientes pasos. Sin spam y sin listas de correo.
      </p>
    </div>

    <form class="contact-form reveal" id="contact-form" action={url('/api/lead/')} method="POST" data-email={CONTACT_EMAIL}>
      <input type="hidden" name="source" value="contacto">
      <div class="contact-form__row">
        <div class="contact-form__field">
          <label for="cf-nombre" class="contact-form__label">Nombre</label>
          <input type="text" id="cf-nombre" name="nombre" class="contact-form__input" required autocomplete="name">
        </div>
        <div class="contact-form__field">
          <label for="cf-email" class="contact-form__label">Email</label>
          <input type="email" id="cf-email" name="email" class="contact-form__input" required autocomplete="email">
        </div>
      </div>
      <div class="contact-form__field">
        <label for="cf-negocio" class="contact-form__label">¿A qué se dedica tu negocio?</label>
        <input type="text" id="cf-negocio" name="negocio" class="contact-form__input" placeholder="Ej.: clínica dental, gestoría, tienda online...">
      </div>
      <div class="contact-form__field">
        <label for="cf-mensaje" class="contact-form__label">¿Qué proceso te quita más tiempo?</label>
        <textarea id="cf-mensaje" name="mensaje" class="contact-form__textarea" rows="4" required placeholder="Ej.: contestar siempre las mismas preguntas por WhatsApp, hacer presupuestos, pasar facturas a mano..."></textarea>
      </div>
      {/* Honeypot anti-spam */}
      <input type="text" name="_gotcha" style="display:none" tabindex="-1" autocomplete="off">
      <button type="submit" class="btn btn--primary btn--lg contact-form__submit">Enviar y reservar mi llamada gratuita</button>
      <p class="contact-form__note">Al enviar aceptas que use estos datos solo para responderte. Nada de newsletters sorpresa.</p>
      <p class="contact-form__feedback" id="contact-feedback" role="status" aria-live="polite" hidden></p>
    </form>
  </div>
</section>

<script is:inline>
(function () {
  var form = document.getElementById('contact-form');
  if (!form) return;
  var feedback = document.getElementById('contact-feedback');
  var btn = form.querySelector('button[type="submit"]');

  form.addEventListener('submit', function (e) {
    e.preventDefault();
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando…'; }
    if (feedback) { feedback.hidden = true; feedback.className = 'contact-form__feedback'; }

    fetch(form.action, {
      method: 'POST',
      headers: { 'Accept': 'application/json' },
      body: new FormData(form)
    })
      .then(function (r) { return r.json().catch(function () { return { ok: r.ok }; }); })
      .then(function (data) {
        if (data && data.ok) {
          form.reset();
          if (feedback) {
            feedback.textContent = '¡Recibido! Te respondo en menos de 24 horas laborables.';
            feedback.classList.add('is-success');
            feedback.hidden = false;
          }
          if (btn) btn.textContent = 'Enviado ✓';
        } else {
          throw new Error((data && data.error) || 'Error');
        }
      })
      .catch(function () {
        if (feedback) {
          feedback.textContent = 'No se pudo enviar. Inténtalo de nuevo o escríbeme a ' + (form.getAttribute('data-email') || '') + '.';
          feedback.classList.add('is-error');
          feedback.hidden = false;
        }
        if (btn) { btn.disabled = false; btn.textContent = 'Enviar y reservar mi llamada gratuita'; }
      });
  });
})();
</script>

</BaseLayout>
