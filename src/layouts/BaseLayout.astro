---
import { url, BASE } from '../utils';
import { SITE_TITLE, SITE_DESCRIPTION, TAGLINE, CONTACT_EMAIL, LINKEDIN_URL, AUTHOR, TWITTER_HANDLE, TWITTER_URL } from '../consts';
import '../styles/style.scss';

interface Props {
  title?: string;
  description?: string;
  ogType?: 'website' | 'article';
  ogImage?: string;
  canonicalUrl?: string;
  publishedTime?: string;
  tags?: string[];
  isHome?: boolean;
}

const {
  title,
  description = SITE_DESCRIPTION,
  ogType = 'website',
  ogImage,
  canonicalUrl,
  publishedTime,
  tags = [],
  isHome = false,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE_TITLE}` : `${SITE_TITLE} — ${TAGLINE}`;
const ogTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const canonical = canonicalUrl ?? Astro.url.href;
const ogImageUrl = new URL(ogImage ?? url('/images/og-image.png'), Astro.url).href;

// Perfiles externos que corroboran la entidad (sameAs), para SEO/GEO.
const sameAs = [LINKEDIN_URL, TWITTER_URL].filter(Boolean);

// Ruta sin el prefijo de la base, para detectar la sección activa
const pathname = Astro.url.pathname;
const currentPath = BASE && pathname.startsWith(BASE) ? pathname.slice(BASE.length) : pathname;
const isServiciosActive = currentPath.startsWith('/servicios');
const isSobreMiActive = currentPath.startsWith('/sobre-mi');
const isBlogActive = currentPath.startsWith('/blog');
const isDiagnosticoActive = currentPath.startsWith('/diagnostico-express');
const isAsesoriasActive = currentPath.startsWith('/ia-para-asesorias');
const isAbogadosActive = currentPath.startsWith('/ia-para-abogados');
const isZonasActive = currentPath.startsWith('/zonas') || currentPath.startsWith('/consultor-ia');

// JSON-LD global: identifica la entidad Eraldia (servicio profesional enfocado a
// asesorías y despachos) y a Gorka como persona, para SEO/GEO. Una sola vez.
const siteUrl = new URL(url('/'), Astro.url).href;
const orgSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'ProfessionalService',
      '@id': `${siteUrl}#eraldia`,
      name: SITE_TITLE,
      description:
        'Consultoría de IA y automatización para asesorías, gestorías y despachos de abogados. Precio cerrado, resultados medibles y sin humo.',
      url: siteUrl,
      email: CONTACT_EMAIL,
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Bilbao',
        addressRegion: 'Bizkaia',
        addressCountry: 'ES',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 43.263, longitude: -2.935 },
      areaServed: [
        { '@type': 'City', name: 'Bilbao' },
        { '@type': 'AdministrativeArea', name: 'Bizkaia' },
        { '@type': 'AdministrativeArea', name: 'País Vasco' },
        { '@type': 'City', name: 'Córdoba' },
        { '@type': 'City', name: 'Sevilla' },
        { '@type': 'City', name: 'Málaga' },
        { '@type': 'AdministrativeArea', name: 'Andalucía' },
        { '@type': 'Country', name: 'España' },
      ],
      serviceType: [
        'Automatización con IA para asesorías y gestorías',
        'Automatización con IA para despachos de abogados',
      ],
      founder: { '@id': `${siteUrl}#gorka` },
      ...(sameAs.length ? { sameAs } : {}),
    },
    {
      '@type': 'Person',
      '@id': `${siteUrl}#gorka`,
      name: AUTHOR,
      jobTitle: 'Consultor de IA para pymes',
      homeLocation: { '@type': 'Place', name: 'Bilbao, País Vasco' },
      worksFor: { '@id': `${siteUrl}#eraldia` },
      ...(sameAs.length ? { sameAs } : {}),
    },
  ],
};

const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>{pageTitle}</title>

  <meta name="description" content={description}>
  <meta name="author" content={AUTHOR}>

  {/* Open Graph */}
  <meta property="og:title" content={ogTitle}>
  <meta property="og:description" content={description}>
  <meta property="og:type" content={ogType}>
  <meta property="og:url" content={canonical}>
  <meta property="og:image" content={ogImageUrl}>
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content={`${SITE_TITLE} — ${TAGLINE}`}>
  <meta property="og:locale" content="es_ES">
  <meta property="og:site_name" content={SITE_TITLE}>
  {publishedTime && <meta property="article:published_time" content={publishedTime}>}
  {tags.map(tag => <meta property="article:tag" content={tag}>)}

  {/* Twitter Card */}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={ogTitle}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content={ogImageUrl}>
  <meta name="twitter:site" content={TWITTER_HANDLE}>
  <meta name="twitter:creator" content={TWITTER_HANDLE}>

  {/* Canonical URL */}
  <link rel="canonical" href={canonical}>

  {/* JSON-LD global: entidad Eraldia + autor (SEO/GEO) */}
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  {/* Favicon */}
  <link rel="icon" href={url('/images/favicon.svg')} type="image/svg+xml">

  {/* Google Fonts: Space Grotesk (títulos) + Inter (texto) + JetBrains Mono (código) */}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700;800&family=Fraunces:ital,opsz,wght@1,9..144,300..600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">

  {/* Feed */}
  <link rel="alternate" type="application/atom+xml" title={`${SITE_TITLE} Feed`} href={url('/atom.xml')}>

  {/* Inline IntersectionObserver para scroll-reveal (< 300 bytes, progressive enhancement) */}
  <script is:inline>
  document.addEventListener("DOMContentLoaded",function(){if(!("IntersectionObserver"in window))return;document.querySelectorAll(".reveal").forEach(function(e){e.style.willChange="opacity,transform"});var o=new IntersectionObserver(function(e){e.forEach(function(e){e.isIntersecting&&(e.target.classList.add("is-visible"),o.unobserve(e.target))})},{threshold:0.15,rootMargin:"0px 0px -40px 0px"});document.querySelectorAll(".reveal").forEach(function(e){o.observe(e)})});
  </script>
</head>
<body>
  <a class="skip-link" href="#main-content">Saltar al contenido</a>
  <div class="page-wrapper">

    <!-- ================================================================ -->
    <!-- Header                                                            -->
    <!-- ================================================================ -->
    <header class={`header${isHome ? ' header--on-hero' : ' header--light'}`}>
      <div class="container header__inner">
        <a href={url('/')} class="header__logo" aria-label="Eraldia">
          <span class="logo-wordmark" aria-hidden="true">eraldia</span>
        </a>

        <input type="checkbox" id="nav-toggle" class="header__nav-toggle" aria-hidden="true">
        <label for="nav-toggle" class="header__toggle-label" aria-label="Abrir o cerrar el menú">
          <span class="header__toggle-bar"></span>
          <span class="header__toggle-bar"></span>
          <span class="header__toggle-bar"></span>
        </label>

        <nav class="header__nav" aria-label="Navegación principal">
          <a href={url('/servicios/')} class={`header__nav-link${isServiciosActive ? ' header__nav-link--active' : ''}`}>Servicios</a>
          <a href={url('/ia-para-asesorias/')} class={`header__nav-link${isAsesoriasActive ? ' header__nav-link--active' : ''}`}>Asesorías</a>
          <a href={url('/ia-para-abogados/')} class={`header__nav-link${isAbogadosActive ? ' header__nav-link--active' : ''}`}>Abogados</a>
          <a href={url('/zonas/')} class={`header__nav-link${isZonasActive ? ' header__nav-link--active' : ''}`}>Zonas</a>
          <a href={url('/sobre-mi/')} class={`header__nav-link${isSobreMiActive ? ' header__nav-link--active' : ''}`}>Sobre mí</a>
          <a href={url('/blog/')} class={`header__nav-link${isBlogActive ? ' header__nav-link--active' : ''}`}>Blog</a>
          <a href={url('/diagnostico-express/')} class={`header__nav-link${isDiagnosticoActive ? ' header__nav-link--active' : ''}`}>Diagnóstico exprés</a>
          <a href={url('/#contacto')} class="header__nav-link">Contacto</a>
        </nav>
      </div>
    </header>

    <!-- ================================================================ -->
    <!-- Main Content                                                      -->
    <!-- ================================================================ -->
    <main class="main" id="main-content">
      <slot />
    </main>

    <!-- ================================================================ -->
    <!-- Footer                                                            -->
    <!-- ================================================================ -->
    <footer class="footer">
      <div class="container footer__inner">
        <div class="footer__top">
          <div class="footer__brand">
            <img src={url('/images/favicon.svg')} alt="Eraldia" class="footer__icon" width="48" height="48">
            <div class="footer__logo"><span class="logo-e" aria-hidden="true">e</span>raldia</div>
            <p class="footer__tagline">{TAGLINE}</p>
          </div>

          <div class="footer__nav">
            <div class="footer__nav-group">
              <div class="footer__nav-title">Servicios</div>
              <ul class="footer__nav-list">
                <li><a href={url('/servicios/')} class="footer__nav-link">Todos los servicios</a></li>
                <li><a href={url('/servicios/diagnostico-ia/')} class="footer__nav-link">Diagnóstico de IA</a></li>
                <li><a href={url('/servicios/automatizacion/')} class="footer__nav-link">Automatización a medida</a></li>
                <li><a href={url('/servicios/acompanamiento/')} class="footer__nav-link">Acompañamiento mensual</a></li>
              </ul>
            </div>

            <div class="footer__nav-group">
              <div class="footer__nav-title">Sectores</div>
              <ul class="footer__nav-list">
                <li><a href={url('/ia-para-asesorias/')} class="footer__nav-link">Asesorías y gestorías</a></li>
                <li><a href={url('/ia-para-abogados/')} class="footer__nav-link">Despachos de abogados</a></li>
                <li><a href={url('/casos/clinicas/')} class="footer__nav-link">Clínicas y centros de salud</a></li>
                <li><a href={url('/casos/gimnasios/')} class="footer__nav-link">Gimnasios y centros deportivos</a></li>
                <li><a href={url('/casos/inmobiliarias/')} class="footer__nav-link">Inmobiliarias</a></li>
              </ul>
            </div>

            <div class="footer__nav-group">
              <div class="footer__nav-title">Zonas</div>
              <ul class="footer__nav-list">
                <li><a href={url('/zonas/')} class="footer__nav-link">Todas las zonas</a></li>
                <li><a href={url('/consultor-ia-bilbao/')} class="footer__nav-link">IA en Bilbao</a></li>
                <li><a href={url('/consultor-ia-pais-vasco/')} class="footer__nav-link">IA en el País Vasco</a></li>
                <li><a href={url('/consultor-ia-cordoba/')} class="footer__nav-link">IA en Córdoba</a></li>
                <li><a href={url('/consultor-ia-sevilla/')} class="footer__nav-link">IA en Sevilla</a></li>
                <li><a href={url('/consultor-ia-malaga/')} class="footer__nav-link">IA en Málaga</a></li>
              </ul>
            </div>

            <div class="footer__nav-group">
              <div class="footer__nav-title">Eraldia</div>
              <ul class="footer__nav-list">
                <li><a href={url('/sobre-mi/')} class="footer__nav-link">Sobre mí</a></li>
                <li><a href={url('/casos/')} class="footer__nav-link">Casos de uso</a></li>
                <li><a href={url('/playbook/')} class="footer__nav-link">Playbook de IA</a></li>
                <li><a href={url('/diagnostico-express/')} class="footer__nav-link">Diagnóstico exprés</a></li>
                <li><a href={url('/blog/')} class="footer__nav-link">Blog</a></li>
              </ul>
            </div>

            <div class="footer__nav-group">
              <div class="footer__nav-title">Contacto</div>
              <ul class="footer__nav-list">
                <li><a href={url('/#contacto')} class="footer__nav-link">Escríbeme</a></li>
                <li><a href={`mailto:${CONTACT_EMAIL}`} class="footer__nav-link">{CONTACT_EMAIL}</a></li>
                {LINKEDIN_URL && (
                  <li><a href={LINKEDIN_URL} class="footer__nav-link" rel="noopener" target="_blank">LinkedIn</a></li>
                )}
                <li><a href={url('/atom.xml')} class="footer__nav-link">RSS</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="footer__bottom">
          <span class="footer__copyright">&copy; {currentYear} {SITE_TITLE} &middot; Gorka Alapont. Todos los derechos reservados.</span>
        </div>
      </div>
    </footer>

  </div>
</body>
</html>
